# 数据库配置（Django DATABASES）
# 使用前可将本文件复制为 config.env 并修改为实际值，或直接在此文件填写

DB_ENGINE=django.db.backends.mysql
DB_NAME=hmxy_db
DB_USER=gpt
DB_PASSWORD=hfw123456
DB_HOST=127.0.0.1
DB_PORT=3306

# 可选：Kamiu Agent 数据库只读查询（Django ORM）需配置以下两项
# DJANGO_SETTINGS_MODULE=llm_review_disscusion.settings
# DJANGO_PROJECT_PATH=/path/to/django_hmxy/llm_review_disscusion

# Redis 缓存（讨论列表/详情/发言/浏览历史），settings 中 CACHES 使用此变量
REDIS_URL=redis://127.0.0.1:6379/1
# 管理员走另一个Redis库
MANAGE_REDIS_URL=redis://127.0.0.1:6379/3