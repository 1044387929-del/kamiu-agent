# 复制本文件为 database.env 并修改下方变量后，配置才会生效
# cp database.env.example database.env

# MySQL（若助手需直连库或调 Django 执行代码时由 Django 使用）
DB_ENGINE=django.db.backends.mysql
DB_NAME=hmxy_db
DB_USER=your_user
DB_PASSWORD=your_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis（若需要缓存等）
REDIS_URL=redis://127.0.0.1:6379/1
MANAGE_REDIS_URL=redis://127.0.0.1:6379/3
